<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="900.0" prefWidth="1440.0" style="-fx-background-color: #fefce8;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">

    <!-- ═══════════════════════════════════════════════════════ -->
    <!--  TOP NAVIGATION BAR                                     -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="70.0" prefWidth="1440.0" style="-fx-background-color: linear-gradient(to right, #ffffff, #fef3c7cc);                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10, 0, 0, 2);">
            <padding>
                <Insets left="60.0" right="30.0" />
            </padding>

            <!-- Logo -->
            <VBox alignment="CENTER_LEFT" spacing="2.0">
                <Label style="-fx-font-family: 'Playfair Display'; -fx-font-size: 30px; -fx-font-weight: bold;                               -fx-text-fill: #ff6b9d;" text="Sassy-me" />
                <Region prefHeight="2.0" prefWidth="140.0" style="-fx-background-color: #ff6b9d; -fx-opacity: 0.5;" />
            </VBox>

            <!-- Spacer -->
            <Region HBox.hgrow="ALWAYS" />

            <!-- Navigation Links -->
            <HBox alignment="CENTER" spacing="30.0">
                <padding>
                    <Insets right="30.0" />
                </padding>

                <VBox alignment="CENTER" spacing="4.0">
                    <Label style="-fx-font-family: 'Inter'; -fx-font-size: 15px; -fx-font-weight: bold;                                   -fx-text-fill: #7c3aed; -fx-cursor: hand;" text="Home" />
                    <Region prefHeight="4.0" prefWidth="60.0" style="-fx-background-color: linear-gradient(to right, #ff6b9d, #ffa500);" />
                </VBox>

                <Label style="-fx-font-family: 'Inter'; -fx-font-size: 15px; -fx-font-weight: 500;                               -fx-text-fill: #6b7280; -fx-cursor: hand;" text="Trending" />

                <Label style="-fx-font-family: 'Inter'; -fx-font-size: 15px; -fx-font-weight: 500;                               -fx-text-fill: #6b7280; -fx-cursor: hand;" text="Tags" />

                <Label style="-fx-font-family: 'Inter'; -fx-font-size: 15px; -fx-font-weight: 500;                               -fx-text-fill: #6b7280; -fx-cursor: hand;" text="Friends" />
            </HBox>

            <!-- New Post Button -->
            <Button fx:id="newPostButton" style="-fx-background-color: #ff6b9d;                            -fx-text-fill: white; -fx-font-family: 'Inter'; -fx-font-size: 14px;                            -fx-font-weight: bold; -fx-cursor: hand; -fx-border-color: transparent;                            -fx-effect: dropshadow(gaussian, rgba(255,107,157,0.5), 8, 0, 0, 0);" text="+ New Post">
                <font>
                    <Font name="System Bold" size="14.0" />
                </font>
                <padding>
                    <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
                </padding>
            </Button>
        </HBox>
    </top>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!--  MAIN CONTENT AREA                                      -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <center>
        <HBox alignment="TOP_CENTER" spacing="20.0">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>

            <!-- ─────────────────────────────────────────────── -->
            <!--  FEED (scrollable post list)                    -->
            <!-- ─────────────────────────────────────────────── -->
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background: transparent; -fx-background-color: transparent;                                -fx-border-color: transparent;" HBox.hgrow="ALWAYS">
                <VBox fx:id="feedContainer" spacing="20.0">
                    <padding>
                        <Insets right="10.0" />
                    </padding>

                    <!-- ════════════════════════════════════════ -->
                    <!--  POST CARD 1 – Disaster in the Kitchen  -->
                    <!-- ════════════════════════════════════════ -->
                    <HBox prefHeight="210.0" style="-fx-background-color: white;                                                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.12), 12, 0, 0, 2);">

                        <!-- Left accent bar -->
                        <Region prefWidth="5.0" style="-fx-background-color: #dc2626;" />

                        <!-- Thumbnail -->
                        <StackPane prefHeight="210.0" prefWidth="195.0" style="-fx-background-color: linear-gradient(to bottom right, #fed7aa, #fbbf24);">
                            <Label style="-fx-font-size: 48px;" text="🍳" />
                        </StackPane>

                        <!-- Post Content -->
                        <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                            <padding>
                                <Insets bottom="18.0" left="20.0" right="20.0" top="18.0" />
                            </padding>

                            <Label style="-fx-font-family: 'Playfair Display'; -fx-font-size: 22px;                                           -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="Disaster in the Kitchen" />

                            <FlowPane hgap="8.0" vgap="6.0">
                                <Button style="-fx-background-color: #dc2626; -fx-text-fill: white;                                                -fx-font-family: 'Inter'; -fx-font-size: 11px;                                                -fx-font-weight: bold; -fx-cursor: hand;                                                -fx-effect: dropshadow(gaussian, rgba(220,38,38,0.4), 6, 0, 0, 0);" text="Disasters / Oh no" />
                                <Button style="-fx-background-color: #4a5568; -fx-text-fill: white;                                                -fx-font-family: 'Inter'; -fx-font-size: 11px;                                                -fx-font-weight: bold; -fx-cursor: hand;" text="Bathroom" />
                            </FlowPane>

                            <!-- Star Rating -->
                            <HBox spacing="2.0">
                                <Label style="-fx-font-size: 18px; -fx-text-fill: #e5e7eb;" text="☆" />
                        <Label layoutX="10.0" layoutY="10.0" style="-fx-font-size: 18px; -fx-text-fill: #e5e7eb;" text="☆" />
                        <Label layoutX="10.0" layoutY="10.0" style="-fx-font-size: 18px; -fx-text-fill: #e5e7eb;" text="☆" />
                        <Label layoutX="50.0" layoutY="10.0" style="-fx-font-size: 18px; -fx-text-fill: #e5e7eb;" text="☆" />
                        <Label layoutX="70.0" layoutY="10.0" style="-fx-font-size: 18px; -fx-text-fill: #e5e7eb;" text="☆" />
                            </HBox>

                            <Label style="-fx-font-family: 'Inter'; -fx-font-size: 15px;                                           -fx-font-weight: 500; -fx-text-fill: #334155;" text="Well, that didn't go as planned... 😅" />

                            <!-- Engagement -->
                            <HBox alignment="CENTER_LEFT" spacing="20.0">
                                <Label style="-fx-font-family: 'Inter'; -fx-font-size: 14px;                                               -fx-font-weight: bold; -fx-text-fill: #ec4899; -fx-cursor: hand;" text="❤ 45" />
                                <Label style="-fx-font-family: 'Inter'; -fx-font-size: 14px;                                               -fx-font-weight: bold; -fx-text-fill: #7c3aed; -fx-cursor: hand;" text="💬 18" />
                            </HBox>
                        </VBox>
                    </HBox>

                    <!-- ════════════════════════════════════════ -->
                    <!--  POST CARD 2 – Epic Movie Night         -->
                    <!-- ════════════════════════════════════════ -->
                    <HBox prefHeight="210.0" style="-fx-background-color: white;                                                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.12), 12, 0, 0, 2);">

                        <!-- Left accent bar -->
                        <Region prefWidth="5.0" style="-fx-background-color: #7c3aed;" />

                        <!-- Thumbnail -->
                        <StackPane prefHeight="210.0" prefWidth="195.0" style="-fx-background-color: linear-gradient(to bottom right, #334155, #0f172a);">
                            <Label style="-fx-font-size: 48px;" text="🎬" />
                        </StackPane>

                        <!-- Post Content -->
                        <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                            <padding>
                                <Insets bottom="18.0" left="20.0" right="20.0" top="18.0" />
                            </padding>

                            <Label style="-fx-font-family: 'Playfair Display'; -fx-font-size: 22px;                                           -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="Epic Movie Night!" />

                            <FlowPane hgap="8.0" vgap="6.0">
                                <Button style="-fx-background-color: #7c3aed; -fx-text-fill: white;                                                -fx-font-family: 'Inter'; -fx-font-size: 11px;                                                -fx-font-weight: bold; -fx-cursor: hand;                                                -fx-effect: dropshadow(gaussian, rgba(124,58,237,0.4), 6, 0, 0, 0);" text="Cinema / Movies" />
                                <Button style="-fx-background-color: #059669; -fx-text-fill: white;                                                -fx-font-family: 'Inter'; -fx-font-size: 11px;                                                -fx-font-weight: bold; -fx-cursor: hand;" text="Food" />
                            </FlowPane>

                            <!-- Star Rating + Favourite -->
                            <HBox alignment="CENTER_LEFT" spacing="2.0">
                        <Label style="-fx-font-size: 18px; -fx-text-fill: #e5e7eb;" text="☆" />
                        <Label style="-fx-font-size: 18px; -fx-text-fill: #e5e7eb;" text="☆" />
                        <Label style="-fx-font-size: 18px; -fx-text-fill: #e5e7eb;" text="☆" />
                        <Label style="-fx-font-size: 18px; -fx-text-fill: #e5e7eb;" text="☆" />
                        <Label style="-fx-font-size: 18px; -fx-text-fill: #e5e7eb;" text="☆" />
                            </HBox>

                            <Label style="-fx-font-family: 'Inter'; -fx-font-size: 15px;                                           -fx-font-weight: 500; -fx-text-fill: #334155;" text="Best movie night ever! 🍿 🎬" />

                            <!-- Engagement -->
                            <HBox alignment="CENTER_LEFT" spacing="20.0">
                                <Label style="-fx-font-family: 'Inter'; -fx-font-size: 14px;                                               -fx-font-weight: bold; -fx-text-fill: #ec4899; -fx-cursor: hand;" text="❤ 87" />
                                <Label style="-fx-font-family: 'Inter'; -fx-font-size: 14px;                                               -fx-font-weight: bold; -fx-text-fill: #7c3aed; -fx-cursor: hand;" text="💬 24" />
                            </HBox>
                        </VBox>
                    </HBox>

                    <!-- ════════════════════════════════════════ -->
                    <!--  POST CARD 3 – Late Night Gaming        -->
                    <!-- ════════════════════════════════════════ -->
                    <HBox prefHeight="210.0" style="-fx-background-color: white;                                                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.12), 12, 0, 0, 2);">

                        <!-- Left accent bar -->
                        <Region prefWidth="5.0" style="-fx-background-color: #3b82f6;" />

                        <!-- Thumbnail -->
                        <StackPane prefHeight="210.0" prefWidth="195.0" style="-fx-background-color: linear-gradient(to bottom right, #60a5fa, #3b82f6);">
                            <Label style="-fx-font-size: 48px;" text="🎮" />
                        </StackPane>

                        <!-- Post Content -->
                        <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                            <padding>
                                <Insets bottom="18.0" left="20.0" right="20.0" top="18.0" />
                            </padding>

                            <Label style="-fx-font-family: 'Playfair Display'; -fx-font-size: 22px;                                           -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="Late Night Gaming" />

                            <FlowPane hgap="8.0" vgap="6.0">
                                <Button style="-fx-background-color: #3b82f6; -fx-text-fill: white;                                                -fx-font-family: 'Inter'; -fx-font-size: 11px;                                                -fx-font-weight: bold; -fx-cursor: hand;                                                -fx-effect: dropshadow(gaussian, rgba(59,130,246,0.4), 6, 0, 0, 0);" text="Videogames" />
                            </FlowPane>

                            <!-- Star Rating -->
                            <HBox spacing="2.0">
                        <children>
                           <Label style="-fx-font-size: 18px; -fx-text-fill: #e5e7eb;" text="☆" />
                           <Label style="-fx-font-size: 18px; -fx-text-fill: #e5e7eb;" text="☆" />
                           <Label style="-fx-font-size: 18px; -fx-text-fill: #e5e7eb;" text="☆" />
                           <Label style="-fx-font-size: 18px; -fx-text-fill: #e5e7eb;" text="☆" />
                           <Label style="-fx-font-size: 18px; -fx-text-fill: #e5e7eb;" text="☆" />
                        </children>
                            </HBox>

                            <Label style="-fx-font-family: 'Inter'; -fx-font-size: 15px;                                           -fx-font-weight: 500; -fx-text-fill: #334155;" text="Finally beat that impossible level! 🎮" />

                            <!-- Engagement -->
                            <HBox alignment="CENTER_LEFT" spacing="20.0">
                                <Label style="-fx-font-family: 'Inter'; -fx-font-size: 14px;                                               -fx-font-weight: bold; -fx-text-fill: #ec4899; -fx-cursor: hand;" text="❤ 32" />
                                <Label style="-fx-font-family: 'Inter'; -fx-font-size: 14px;                                               -fx-font-weight: bold; -fx-text-fill: #7c3aed; -fx-cursor: hand;" text="💬 9" />
                            </HBox>
                        </VBox>
                    </HBox>

                </VBox>
            </ScrollPane>

            <!-- ─────────────────────────────────────────────── -->
            <!--  RIGHT SIDEBAR – Trending Tags                  -->
            <!-- ─────────────────────────────────────────────── -->
            <VBox prefWidth="260.0" spacing="0.0" style="-fx-background-color: linear-gradient(to bottom, #ffffff, rgba(254,243,199,0.3));                          -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 8, 0, 0, 2);">

                <!-- Gradient top accent -->
                <Region prefHeight="6.0" style="-fx-background-color: linear-gradient(to right, #ff6b9d, #ffa500);" />

                <VBox spacing="0.0">
                    <padding>
                        <Insets bottom="20.0" left="25.0" right="15.0" top="15.0" />
                    </padding>

                    <Label style="-fx-font-family: 'Playfair Display'; -fx-font-size: 22px;                                   -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="Trending Tags">
                        <VBox.margin>
                            <Insets bottom="12.0" />
                        </VBox.margin>
                    </Label>

                    <!-- Tag Item 1 -->
                    <VBox spacing="2.0" style="-fx-background-color: rgba(243,232,255,0.5);">
                        <padding><Insets bottom="10.0" left="10.0" right="10.0" top="10.0" /></padding>
                        <Label style="-fx-font-family: 'Inter'; -fx-font-size: 16px;                                       -fx-font-weight: bold; -fx-text-fill: #7c3aed; -fx-cursor: hand;" text="#Cinema" />
                        <Label style="-fx-font-family: 'Inter'; -fx-font-size: 13px; -fx-text-fill: #6b7280;" text="1.2k posts" />
                    </VBox>
                    <Separator style="-fx-opacity: 0.3;" />

                    <!-- Tag Item 2 -->
                    <VBox spacing="2.0" style="-fx-background-color: rgba(209,250,229,0.5);">
                        <padding><Insets bottom="10.0" left="10.0" right="10.0" top="10.0" /></padding>
                        <Label style="-fx-font-family: 'Inter'; -fx-font-size: 16px;                                       -fx-font-weight: bold; -fx-text-fill: #059669; -fx-cursor: hand;" text="#Food" />
                        <Label style="-fx-font-family: 'Inter'; -fx-font-size: 13px; -fx-text-fill: #6b7280;" text="890 posts" />
                    </VBox>
                    <Separator style="-fx-opacity: 0.3;" />

                    <!-- Tag Item 3 -->
                    <VBox spacing="2.0" style="-fx-background-color: rgba(219,234,254,0.5);">
                        <padding><Insets bottom="10.0" left="10.0" right="10.0" top="10.0" /></padding>
                        <Label style="-fx-font-family: 'Inter'; -fx-font-size: 16px;                                       -fx-font-weight: bold; -fx-text-fill: #3b82f6; -fx-cursor: hand;" text="#Videogames" />
                        <Label style="-fx-font-family: 'Inter'; -fx-font-size: 13px; -fx-text-fill: #6b7280;" text="756 posts" />
                    </VBox>
                    <Separator style="-fx-opacity: 0.3;" />

                    <!-- Tag Item 4 -->
                    <VBox spacing="2.0" style="-fx-background-color: rgba(254,226,226,0.5);">
                        <padding><Insets bottom="10.0" left="10.0" right="10.0" top="10.0" /></padding>
                        <Label style="-fx-font-family: 'Inter'; -fx-font-size: 16px;                                       -fx-font-weight: bold; -fx-text-fill: #dc2626; -fx-cursor: hand;" text="#Disasters" />
                        <Label style="-fx-font-family: 'Inter'; -fx-font-size: 13px; -fx-text-fill: #6b7280;" text="623 posts" />
                    </VBox>
                    <Separator style="-fx-opacity: 0.3;" />

                    <!-- Tag Item 5 -->
                    <VBox spacing="2.0" style="-fx-background-color: rgba(231,229,228,0.5);">
                        <padding><Insets bottom="10.0" left="10.0" right="10.0" top="10.0" /></padding>
                        <Label style="-fx-font-family: 'Inter'; -fx-font-size: 16px;                                       -fx-font-weight: bold; -fx-text-fill: #78716c; -fx-cursor: hand;" text="#Books" />
                        <Label style="-fx-font-family: 'Inter'; -fx-font-size: 13px; -fx-text-fill: #6b7280;" text="445 posts" />
                    </VBox>
                    <Separator style="-fx-opacity: 0.3;" />

                    <!-- Tag Item 6 -->
                    <VBox spacing="2.0" style="-fx-background-color: rgba(252,231,243,0.5);">
                        <padding><Insets bottom="10.0" left="10.0" right="10.0" top="10.0" /></padding>
                        <Label style="-fx-font-family: 'Inter'; -fx-font-size: 16px;                                       -fx-font-weight: bold; -fx-text-fill: #db2777; -fx-cursor: hand;" text="#Music" />
                        <Label style="-fx-font-family: 'Inter'; -fx-font-size: 13px; -fx-text-fill: #6b7280;" text="389 posts" />
                    </VBox>

                </VBox>
            </VBox>

        </HBox>
    </center>

</BorderPane>
