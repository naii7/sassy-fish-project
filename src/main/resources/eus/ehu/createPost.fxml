<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="800.0" prefWidth="1000.0" style="-fx-background-color: #fefce8;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="eus.ehu.controllers.CreatePostController">
   
   <!-- Header -->
   <top>
      <HBox alignment="CENTER_LEFT" prefHeight="70.0" prefWidth="1440.0" style="-fx-background-color: linear-gradient(to right, #ffffff, #fef3c7cc);                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10, 0, 0, 2);">
         <padding>
            <Insets left="60.0" right="30.0" />
         </padding>

         <!-- Logo -->
         <VBox alignment="CENTER_LEFT" spacing="2.0">
            <Label style="-fx-font-family: 'Playfair Display'; -fx-font-size: 30px; -fx-font-weight: bold;                               -fx-text-fill: #ff6b9d;" text="Sassy-me" />
            <Region prefHeight="2.0" prefWidth="140.0" style="-fx-background-color: #ff6b9d; -fx-opacity: 0.5;" />
         </VBox>

         <!-- Spacer -->
         <Region HBox.hgrow="ALWAYS" />

         <!-- Navigation Links -->
         <HBox alignment="CENTER" spacing="30.0">
            <padding>
               <Insets right="30.0" />
            </padding>

            <VBox alignment="CENTER" spacing="4.0">
               <Label style="-fx-font-family: 'Inter'; -fx-font-size: 15px; -fx-font-weight: bold;                                   -fx-text-fill: #7c3aed; -fx-cursor: hand;" text="Home" />
               <Region prefHeight="4.0" prefWidth="60.0" style="-fx-background-color: linear-gradient(to right, #ff6b9d, #ffa500);" />
            </VBox>

            <Label style="-fx-font-family: 'Inter'; -fx-font-size: 15px; -fx-font-weight: 500;                               -fx-text-fill: #6b7280; -fx-cursor: hand;" text="Trending" />

            <Label style="-fx-font-family: 'Inter'; -fx-font-size: 15px; -fx-font-weight: 500;                               -fx-text-fill: #6b7280; -fx-cursor: hand;" text="Tags" />

            <Label style="-fx-font-family: 'Inter'; -fx-font-size: 15px; -fx-font-weight: 500;                               -fx-text-fill: #6b7280; -fx-cursor: hand;" text="Friends" />
            <Button fx:id="profileButton" onAction="#openProfile" style="-fx-background-color: #ffffff;                            -fx-text-fill: #7c3aed; -fx-font-family: 'Inter'; -fx-font-size: 14px;                            -fx-font-weight: bold; -fx-cursor: hand; -fx-border-color: #7c3aed;                            -fx-border-width: 1.5;" text="Profile">
               <padding>
                  <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
               </padding>
            </Button>

            <!-- New Post Button -->
            <Button fx:id="newPostButton" onAction="#newPostButtonClicked" style="-fx-background-color: #ff6b9d;                            -fx-text-fill: white; -fx-font-family: 'Inter'; -fx-font-size: 14px;                            -fx-font-weight: bold; -fx-cursor: hand; -fx-border-color: transparent;                            -fx-effect: dropshadow(gaussian, rgba(255,107,157,0.5), 8, 0, 0, 0);" text="+ New Post">
               <font>
                  <Font name="System Bold" size="14.0" />
               </font>
               <padding>
                  <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
               </padding>
            </Button>
         </HBox>
      </HBox>
   </top>

   <!-- Content -->
   <center>
      <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;">
         <VBox alignment="TOP_CENTER" prefWidth="500.0" spacing="15.0">
   <!-- Content -->
   <center>
      <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;">
         <VBox alignment="TOP_CENTER" prefWidth="500.0" spacing="15.0">
            <padding>
               <Insets bottom="20.0" left="25.0" right="25.0" top="20.0" />
            </padding>
            <AnchorPane prefHeight="200.0" prefWidth="200.0">
               <children>
                  <Label text="Create New Post">
                     <font>
                        <Font name="System Bold" size="24.0" />
                     </font>
                  </Label>
                  <Label fx:id="dateLabel" layoutX="323.0" layoutY="9.0" prefHeight="17.0" prefWidth="79.0" textAlignment="RIGHT" />
               </children>
            </AnchorPane>
            <AnchorPane fx:id="imageDropArea" prefHeight="150.0" prefWidth="300.0" style="-fx-border-color: black;">
               <children>
                  <Label fx:id="imageUploadLabel" layoutX="138.0" layoutY="65.0" prefHeight="20.0" prefWidth="124.0" style="-fx-font-weight: bold; -fx-font-size: 14px;" text="📷 Upload Image *" />
                  <ImageView fx:id="imageView" fitHeight="150.0" fitWidth="400.0" onMouseClicked="#handleImageClick" pickOnBounds="true" preserveRatio="true" />
               </children>
            </AnchorPane>

            <VBox spacing="5.0">
               <Label fx:id="titleLabel" prefHeight="17.0" prefWidth="42.0" style="-fx-font-weight: bold;" text="Title *" />
               <TextField fx:id="titleField" promptText="Enter title..." />
            </VBox>

            <VBox spacing="5.0">
               <Label fx:id="descriptionLabel" style="-fx-font-weight: bold;" text="Description" />
               <TextArea fx:id="descriptionField" prefHeight="80.0" promptText="Enter description..." wrapText="true" />
            </VBox>

            <VBox spacing="5.0">
               <Label fx:id="tagsLabel" prefHeight="17.0" prefWidth="52.0" style="-fx-font-weight: bold;" text="Tags *" />
               <AnchorPane fx:id="tagContainer" prefHeight="200.0" prefWidth="200.0">
                  <children>
                     <CheckBox layoutX="14.0" layoutY="44.0" mnemonicParsing="false" text="Food" textFill="#6aa84f" />
                     <CheckBox layoutX="14.0" layoutY="74.0" mnemonicParsing="false" text="Movie" textFill="#cc0000" />
                     <CheckBox layoutX="303.0" layoutY="74.0" mnemonicParsing="false" text="Book" textFill="#cc0000" />
                     <CheckBox layoutX="105.0" layoutY="74.0" mnemonicParsing="false" text="Music" textFill="#cc0000" />
                     <CheckBox layoutX="193.0" layoutY="74.0" mnemonicParsing="false" text="Videogame" textFill="#cc0000" />
                     <CheckBox layoutX="15.0" layoutY="104.0" mnemonicParsing="false" text="Other" textFill="#ffca69" />
                     <CheckBox layoutX="14.0" layoutY="15.0" mnemonicParsing="false" text="Bathroom" textFill="#3d85c6" />
                     <CheckBox layoutX="105.0" layoutY="16.0" mnemonicParsing="false" text="Disaster" textFill="#3d85c6" />
                  </children>
               </AnchorPane>
            </VBox>

            <VBox prefHeight="81.0" prefWidth="402.0" spacing="5.0">
               <Label fx:id="starsLabel" prefHeight="17.0" prefWidth="79.0" style="-fx-font-weight: bold;" text="Star Rating *" />
               <HBox fx:id="starContainer">
                  <children>
                     <Label fx:id="star1" onMouseClicked="#handleStarClicked" text=" ★" textFill="#b9b9b9">
                        <font>
                           <Font size="36.0" />
                        </font>
                     </Label>
                     <Label fx:id="star2" onMouseClicked="#handleStarClicked" text=" ★" textFill="#b9b9b9">
                        <font>
                           <Font size="36.0" />
                        </font>
                     </Label>
                     <Label fx:id="star3" onMouseClicked="#handleStarClicked" text=" ★" textFill="#b9b9b9">
                        <font>
                           <Font size="36.0" />
                        </font>
                     </Label>
                     <Label fx:id="star4" onMouseClicked="#handleStarClicked" text=" ★" textFill="#b9b9b9">
                        <font>
                           <Font size="36.0" />
                        </font>
                     </Label>
                     <Label fx:id="star5" onMouseClicked="#handleStarClicked" text=" ★" textFill="#b9b9b9">
                        <font>
                           <Font size="36.0" />
                        </font>
                     </Label>
                  </children>
               </HBox>
            </VBox>
            <AnchorPane prefHeight="81.0" prefWidth="402.0">
               <children>
                  <Label fx:id="favouriteLabel" layoutY="20.0" prefHeight="35.0" prefWidth="65.0" style="-fx-font-weight: bold;" text="Favourite" />      
                  <Button fx:id="cancelPostButton" layoutX="245.0" layoutY="23.0" onAction="#cancelPost" prefHeight="29.0" prefWidth="63.0" style="-fx-font-weight: bold;" text="Cancel" />
                  <Button fx:id="createPostButton" layoutX="319.0" layoutY="24.0" onAction="#savePost" style="-fx-font-weight: bold; -fx-font-size: 14px;" text="Save Post" />
                  <ToggleButton fx:id="favouriteButton" alignment="CENTER_LEFT" layoutX="40.0" layoutY="-2.0" onAction="#handleFavoriteToggle" prefHeight="68.0" prefWidth="118.0" style="-fx-background-color: transparent; -fx-font-size: 40px;" text="♥" textFill="#b9b9b9">
                     <font>
                        <Font size="40.0" />
                     </font>
                  </ToggleButton>
                  <Label fx:id="errorLabel" layoutX="192.0" layoutY="61.0" prefHeight="17.0" prefWidth="210.0" style="-fx-background-color: red;" text="Please fill in all required fields" textFill="WHITE" visible="false">
                     <font>
                        <Font name="System Bold" size="12.0" />
                     </font>
                  </Label>
               </children>
            </AnchorPane>
         </VBox>
      </ScrollPane>
   </center>
</BorderPane>
