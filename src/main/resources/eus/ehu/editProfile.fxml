<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="800.0" prefWidth="1000.0" style="-fx-background-color: #fefce8;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="eus.ehu.controllers.ProfileController">
   
   <top>
      <HBox alignment="CENTER_LEFT" prefHeight="70.0" prefWidth="1440.0" style="-fx-background-color: linear-gradient(to right, #ffffff, #fef3c7cc); -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10, 0, 0, 2);">
         <padding>
            <Insets left="60.0" right="30.0" />
         </padding>

         <VBox alignment="CENTER_LEFT" spacing="2.0">
            <Label style="-fx-font-family: 'Playfair Display'; -fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #ff6b9d;" text="Sassy-me" />
            <Region prefHeight="2.0" prefWidth="140.0" style="-fx-background-color: #ff6b9d; -fx-opacity: 0.5;" />
         </VBox>

         <Region HBox.hgrow="ALWAYS" />

         <HBox alignment="CENTER" spacing="30.0">
            <padding>
               <Insets right="30.0" />
            </padding>

            <VBox alignment="CENTER" spacing="4.0">
               <Label onMouseClicked="#homeButtonClicked" style="-fx-font-family: 'Inter'; -fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #7c3aed; -fx-cursor: hand;" text="Home" />
               <Region prefHeight="4.0" prefWidth="60.0" style="-fx-background-color: linear-gradient(to right, #ff6b9d, #ffa500);" />
            </VBox>

            <Label style="-fx-font-family: 'Inter'; -fx-font-size: 15px; -fx-font-weight: 500; -fx-text-fill: #6b7280; -fx-cursor: hand;" text="Trending" />

            <Label style="-fx-font-family: 'Inter'; -fx-font-size: 15px; -fx-font-weight: 500; -fx-text-fill: #6b7280; -fx-cursor: hand;" text="Tags" />

            <Label style="-fx-font-family: 'Inter'; -fx-font-size: 15px; -fx-font-weight: 500; -fx-text-fill: #6b7280; -fx-cursor: hand;" text="Friends" />
            
            <Button fx:id="profileButton" onAction="#openProfile" style="-fx-background-color: #ffffff; -fx-text-fill: #7c3aed; -fx-font-family: 'Inter'; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand; -fx-border-color: #7c3aed; -fx-border-width: 1.5; -fx-background-radius: 8; -fx-border-radius: 8;" text="Profile">
               <padding>
                  <Insets bottom="8.0" left="18.0" right="18.0" top="8.0" />
               </padding>
            </Button>

            <Button fx:id="newPostButton" onAction="#newPostButtonClicked" style="-fx-background-color: linear-gradient(to right, #ff6b9d, #ffa500); -fx-text-fill: white; -fx-font-family: 'Inter'; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand; -fx-border-color: transparent; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(255,107,157,0.4), 8, 0, 0, 2);" text="+ New Post">
               <padding>
                  <Insets bottom="8.0" left="18.0" right="18.0" top="8.0" />
               </padding>
            </Button>
         </HBox>
      </HBox>