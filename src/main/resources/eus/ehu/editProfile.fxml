<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.ScrollPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="800.0" prefWidth="1000.0" style="-fx-background-color: #fefce8;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="eus.ehu.controllers.ProfileController">
   
   <!-- Header -->
   <top>
      <HBox alignment="CENTER_LEFT" prefHeight="70.0" prefWidth="1440.0" style="-fx-background-color: linear-gradient(to right, #ffffff, #fef3c7cc);                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10, 0, 0, 2);">
         <padding>
            <Insets left="60.0" right="30.0" />
         </padding>

         <!-- Logo -->
         <VBox alignment="CENTER_LEFT" spacing="2.0">
            <Label style="-fx-font-family: 'Playfair Display'; -fx-font-size: 30px; -fx-font-weight: bold;                               -fx-text-fill: #ff6b9d;" text="Sassy-me" />
            <Region prefHeight="2.0" prefWidth="140.0" style="-fx-background-color: #ff6b9d; -fx-opacity: 0.5;" />
         </VBox>

         <!-- Spacer -->
         <Region HBox.hgrow="ALWAYS" />

         <!-- Navigation Links -->
         <HBox alignment="CENTER" spacing="30.0">
            <padding>
               <Insets right="30.0" />
            </padding>

            <VBox alignment="CENTER" spacing="4.0">
               <Label style="-fx-font-family: 'Inter'; -fx-font-size: 15px; -fx-font-weight: bold;                                   -fx-text-fill: #7c3aed; -fx-cursor: hand;" text="Home" />
               <Region prefHeight="4.0" prefWidth="60.0" style="-fx-background-color: linear-gradient(to right, #ff6b9d, #ffa500);" />
            </VBox>

            <Label style="-fx-font-family: 'Inter'; -fx-font-size: 15px; -fx-font-weight: 500;                               -fx-text-fill: #6b7280; -fx-cursor: hand;" text="Trending" />

            <Label style="-fx-font-family: 'Inter'; -fx-font-size: 15px; -fx-font-weight: 500;                               -fx-text-fill: #6b7280; -fx-cursor: hand;" text="Tags" />

            <Label style="-fx-font-family: 'Inter'; -fx-font-size: 15px; -fx-font-weight: 500;                               -fx-text-fill: #6b7280; -fx-cursor: hand;" text="Friends" />
            <Button fx:id="profileButton" onAction="#openProfile" style="-fx-background-color: #ffffff;                            -fx-text-fill: #7c3aed; -fx-font-family: 'Inter'; -fx-font-size: 14px;                            -fx-font-weight: bold; -fx-cursor: hand; -fx-border-color: #7c3aed;                            -fx-border-width: 1.5;" text="Profile">
               <padding>
                  <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
               </padding>
            </Button>

            <!-- New Post Button -->
            <Button fx:id="newPostButton" onAction="#newPostButtonClicked" style="-fx-background-color: #ff6b9d;                            -fx-text-fill: white; -fx-font-family: 'Inter'; -fx-font-size: 14px;                            -fx-font-weight: bold; -fx-cursor: hand; -fx-border-color: transparent;                            -fx-effect: dropshadow(gaussian, rgba(255,107,157,0.5), 8, 0, 0, 0);" text="+ New Post">
               <font>
                  <Font name="System Bold" size="14.0" />
               </font>
               <padding>
                  <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
               </padding>
            </Button>
         </HBox>
      </HBox>
   </top>

   <!-- Content -->
   <center>
      <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;">
         <VBox alignment="TOP_CENTER" prefWidth="500.0" spacing="15.0">
            <padding>
               <Insets bottom="20.0" left="25.0" right="25.0" top="20.0" />
            </padding>
            <AnchorPane prefHeight="36.0" prefWidth="349.0">
               <children>
                  <Label layoutX="92.0" text="EDIT YOUR PROFILE" textAlignment="CENTER">
                     <font>
                        <Font name="System Bold" size="24.0" />
                     </font>
                  </Label>
                  <Label fx:id="dateLabel" layoutX="323.0" layoutY="9.0" prefHeight="17.0" prefWidth="79.0" textAlignment="RIGHT" />
               </children>
            </AnchorPane>
            <AnchorPane fx:id="imageUploadArea" prefHeight="160.0" prefWidth="300.0" style="-fx-border-color: black;">
               <children>
                  <Label fx:id="uploadImageLabel" layoutX="138.0" layoutY="65.0" prefHeight="20.0" prefWidth="143.0" style="-fx-font-weight: bold; -fx-font-size: 14px;" text="📷 Upload Image *" />
                  <ImageView fx:id="profileImageView" fitHeight="150.0" fitWidth="408.0" layoutX="-2.0" onMouseClicked="#handleImageClick" pickOnBounds="true" preserveRatio="true" />
               </children>
            </AnchorPane>

            <VBox prefHeight="22.0" prefWidth="349.0" spacing="5.0">
               <Label fx:id="usernameField" prefHeight="18.0" prefWidth="215.0" style="-fx-font-weight: bold;" text="New Username" />
               <TextField fx:id="usernameField" prefHeight="25.0" prefWidth="200.0" promptText="Enter new username..." />
            </VBox>

            <VBox prefHeight="59.0" prefWidth="379.0" spacing="5.0">
               <Label fx:id="descriptionLabel" style="-fx-font-weight: bold;" text="Description" />
               <TextArea fx:id="descriptionField" prefHeight="37.0" prefWidth="200.0" promptText="Enter description..." wrapText="true" />
            </VBox>

            <VBox prefHeight="172.0" prefWidth="315.0" spacing="5.0">
               <Label fx:id="favouritesLabel" prefHeight="18.0" prefWidth="155.0" style="-fx-font-weight: bold;" text="Edit Favourites" />
               <HBox fx:id="favouritesContainer" prefHeight="150.0" prefWidth="200.0">
                  <children>
                     <ImageView fx:id="fav1" fitHeight="150.0" fitWidth="42.0" pickOnBounds="true" preserveRatio="true" />
                     <ImageView fx:id="fav2" fitHeight="150.0" fitWidth="65.0" pickOnBounds="true" preserveRatio="true" />
                     <ImageView fx:id="fav3" fitHeight="150.0" fitWidth="44.0" pickOnBounds="true" preserveRatio="true" />
                  </children>
               </HBox>
            </VBox>
            <ImageView fitHeight="150.0" fitWidth="72.0" pickOnBounds="true" preserveRatio="true" />
            <AnchorPane prefHeight="56.0" prefWidth="321.0">
               <children>      
                  <Button fx:id="cancelButton" layoutX="75.0" layoutY="23.0" onAction="#cancelPost" prefHeight="30.0" prefWidth="75.0" style="-fx-font-weight: bold;" text="Cancel" />
                  <Button fx:id="saveButton" layoutX="143.0" layoutY="27.0" onAction="#savePost" style="-fx-font-weight: bold; -fx-font-size: 14px;" text="Save Changes" />
               </children>
            </AnchorPane>
         </VBox>
      </ScrollPane>
   </center>
</BorderPane>
