<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="720.0" prefWidth="1200.0" style="-fx-background-color: #fefce8;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="eus.ehu.controllers.ProfileController">
   <top>
      <HBox alignment="CENTER_LEFT" prefHeight="70.0" prefWidth="1440.0" style="-fx-background-color: linear-gradient(to right, #ffffff, #fef3c7cc);                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10, 0, 0, 2);">
         <padding>
            <Insets left="60.0" right="30.0" />
         </padding>

         <!-- Logo -->
         <VBox alignment="CENTER_LEFT" spacing="2.0">
            <Label style="-fx-font-family: 'Playfair Display'; -fx-font-size: 30px; -fx-font-weight: bold;                               -fx-text-fill: #ff6b9d;" text="Sassy-me" />
            <Region prefHeight="2.0" prefWidth="140.0" style="-fx-background-color: #ff6b9d; -fx-opacity: 0.5;" />
         </VBox>

         <!-- Spacer -->
         <Region HBox.hgrow="ALWAYS" />

         <!-- Navigation Links -->
         <HBox alignment="CENTER" spacing="30.0">
            <padding>
               <Insets right="30.0" />
            </padding>

            <VBox alignment="CENTER" spacing="4.0">
               <Label onMouseClicked="#homeButtonClicked" style="-fx-font-family: 'Inter'; -fx-font-size: 15px; -fx-font-weight: bold;                                   -fx-text-fill: #7c3aed; -fx-cursor: hand;" text="Home" />
               <Region prefHeight="4.0" prefWidth="60.0" style="-fx-background-color: linear-gradient(to right, #ff6b9d, #ffa500);" />
            </VBox>

            <Label style="-fx-font-family: 'Inter'; -fx-font-size: 15px; -fx-font-weight: 500;                               -fx-text-fill: #6b7280; -fx-cursor: hand;" text="Trending" />

            <Label style="-fx-font-family: 'Inter'; -fx-font-size: 15px; -fx-font-weight: 500;                               -fx-text-fill: #6b7280; -fx-cursor: hand;" text="Tags" />

            <Label style="-fx-font-family: 'Inter'; -fx-font-size: 15px; -fx-font-weight: 500;                               -fx-text-fill: #6b7280; -fx-cursor: hand;" text="Friends" />
            <Button fx:id="profileButton" onAction="#openProfile" style="-fx-background-color: #ffffff;                            -fx-text-fill: #7c3aed; -fx-font-family: 'Inter'; -fx-font-size: 14px;                            -fx-font-weight: bold; -fx-cursor: hand; -fx-border-color: #7c3aed;                            -fx-border-width: 1.5;" text="Profile">
               <padding>
                  <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
               </padding>
            </Button>

            <!-- New Post Button -->
            <Button fx:id="newPostButton" onAction="#newPostButtonClicked" style="-fx-background-color: #ff6b9d;                            -fx-text-fill: white; -fx-font-family: 'Inter'; -fx-font-size: 14px;                            -fx-font-weight: bold; -fx-cursor: hand; -fx-border-color: transparent;                            -fx-effect: dropshadow(gaussian, rgba(255,107,157,0.5), 8, 0, 0, 0);" text="+ New Post">
               <font>
                  <Font name="System Bold" size="14.0" />
               </font>
               <padding>
                  <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
               </padding>
            </Button>
         </HBox>
      </HBox>
   </top>
   <center>
      <HBox spacing="24.0">
         <padding>
            <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
         </padding>
         <ScrollPane fx:id="profileScroll" fitToWidth="true" hbarPolicy="NEVER" prefWidth="360.0" style="-fx-background-color: transparent; -fx-background: transparent;" HBox.hgrow="NEVER">
            <content>
               <VBox spacing="18.0" style="-fx-background-color: white; -fx-background-radius: 20; -fx-border-radius: 20; -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.08), 18, 0, 0, 4);">
                  <padding>
                     <Insets bottom="24.0" left="22.0" right="22.0" top="22.0" />
                  </padding>
                  <VBox spacing="14.0">
                     <children>
                        <StackPane alignment="CENTER">
                           <children>
                              <ImageView fx:id="profileImageView" fitHeight="170.0" fitWidth="170.0" onMouseClicked="#handleProfileImageClicked" pickOnBounds="true" preserveRatio="true" />
                              <ImageView fx:id="editIcon" fitHeight="24.0" fitWidth="24.0" layoutX="130.0" layoutY="130.0" onMouseClicked="#handleProfileImageClicked" pickOnBounds="true" preserveRatio="true" />
                           </children>
                        </StackPane>
                        <Label style="-fx-font-family: 'Inter'; -fx-font-size: 13px; -fx-text-fill: #64748b;" text="User" />
                        <TextField fx:id="usernameField" style="-fx-font-family: 'Inter'; -fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0f172a; -fx-background-color: #f8fafc; -fx-background-radius: 14; -fx-border-color: #e2e8f0; -fx-border-radius: 14; -fx-padding: 10 12;" text="user" />
                        <Label style="-fx-font-family: 'Inter'; -fx-font-size: 13px; -fx-text-fill: #64748b;" text="Bio" />
                        <TextField fx:id="bioField" style="-fx-font-family: 'Inter'; -fx-font-size: 14px; -fx-text-fill: #334155; -fx-background-color: #f8fafc; -fx-background-radius: 14; -fx-border-color: #e2e8f0; -fx-border-radius: 14; -fx-padding: 10 12;" text="user's bio" />
                     </children>
                  </VBox>
                  <Separator />
                  <VBox spacing="12.0">
                     <children>
                        <Label style="-fx-font-family: 'System'; -fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #7c3aed;" text="Favourites" />
                        <Region prefHeight="3.0" prefWidth="70.0" style="-fx-background-color: linear-gradient(to right, #ff6b9d, #ffa500);" />
                        <HBox spacing="12.0">
                           <children>
                              <ImageView fx:id="favourite1" fitHeight="95.0" fitWidth="95.0" onMouseClicked="#handleFavouriteClicked" pickOnBounds="true" preserveRatio="true" />
                              <ImageView fx:id="favourite2" fitHeight="95.0" fitWidth="95.0" onMouseClicked="#handleFavouriteClicked" pickOnBounds="true" preserveRatio="true" />
                              <ImageView fx:id="favourite3" fitHeight="95.0" fitWidth="95.0" onMouseClicked="#handleFavouriteClicked" pickOnBounds="true" preserveRatio="true" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </VBox>
            </content>
         </ScrollPane>

         <ScrollPane fx:id="feedScroll" fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;" HBox.hgrow="ALWAYS">
            <content>
               <VBox fx:id="feedContainer" spacing="16.0" style="-fx-background-color: transparent;">
                  <padding>
                     <Insets bottom="4.0" left="4.0" right="16.0" top="4.0" />
                  </padding>
               </VBox>
            </content>
         </ScrollPane>
      </HBox>
   </center>
   <bottom>
      <AnchorPane prefHeight="82.0" prefWidth="1200.0" BorderPane.alignment="CENTER">
         <children>
            <Button fx:id="backButton" layoutX="39.0" layoutY="29.0" mnemonicParsing="false" onAction="#backButtonClicked" style="-fx-background-color: transparent; -fx-text-fill: #475569; -fx-border-color: #cbd5e1; -fx-border-width: 1; -fx-background-radius: 999; -fx-border-radius: 999; -fx-font-family: 'Inter'; -fx-font-weight: bold; -fx-cursor: hand;" text="Back" visible="false" />
            <Button fx:id="saveChangesButton" layoutX="150.0" layoutY="29.0" mnemonicParsing="false" onAction="#saveChangesButtonClicked" style="-fx-background-color: linear-gradient(to right, #ff6b9d, #ffa500); -fx-text-fill: white; -fx-font-family: 'Inter'; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 999; -fx-cursor: hand;" text="Save Changes" visible="false" />
            <Button fx:id="editProfileButton" layoutX="39.0" layoutY="29.0" mnemonicParsing="false" onAction="#editProfile" style="-fx-background-color: #ff6b9d; -fx-text-fill: white; -fx-font-family: 'Inter'; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 999; -fx-cursor: hand;" text="Edit Profile" />
         </children>
      </AnchorPane>
   </bottom>
</BorderPane>
