<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="600.0" prefWidth="1000.0" style="-fx-background-color: #fefce8;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="eus.ehu.controllers.FeedController">

    <!-- ═══════════════════════════════════════════════════════ -->
    <!--  TOP NAVIGATION BAR                                     -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="70.0" prefWidth="1440.0" style="-fx-background-color: linear-gradient(to right, #ffffff, #fef3c7cc);                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10, 0, 0, 2);">
            <padding>
                <Insets left="60.0" right="30.0" />
            </padding>

            <!-- Logo -->
            <VBox alignment="CENTER_LEFT" spacing="2.0">
                <Label style="-fx-font-family: 'Playfair Display'; -fx-font-size: 30px; -fx-font-weight: bold;                               -fx-text-fill: #ff6b9d;" text="Sassy-me" />
                <Region prefHeight="2.0" prefWidth="140.0" style="-fx-background-color: #ff6b9d; -fx-opacity: 0.5;" />
            </VBox>

            <!-- Spacer -->
            <Region HBox.hgrow="ALWAYS" />

            <!-- Navigation Links -->
            <HBox alignment="CENTER" spacing="30.0">
                <padding>
                    <Insets right="30.0" />
                </padding>

                <VBox alignment="CENTER" spacing="4.0">
                    <Label style="-fx-font-family: 'Inter'; -fx-font-size: 15px; -fx-font-weight: bold;                                   -fx-text-fill: #7c3aed; -fx-cursor: hand;" text="Home" />
                    <Region prefHeight="4.0" prefWidth="60.0" style="-fx-background-color: linear-gradient(to right, #ff6b9d, #ffa500);" />
                </VBox>

                <Label style="-fx-font-family: 'Inter'; -fx-font-size: 15px; -fx-font-weight: 500;                               -fx-text-fill: #6b7280; -fx-cursor: hand;" text="Trending" />

                <Label style="-fx-font-family: 'Inter'; -fx-font-size: 15px; -fx-font-weight: 500;                               -fx-text-fill: #6b7280; -fx-cursor: hand;" text="Tags" />

                <Label style="-fx-font-family: 'Inter'; -fx-font-size: 15px; -fx-font-weight: 500;                               -fx-text-fill: #6b7280; -fx-cursor: hand;" text="Friends" />
            <Button fx:id="profileButton" onAction="#openProfile" style="-fx-background-color: #ffffff;                            -fx-text-fill: #7c3aed; -fx-font-family: 'Inter'; -fx-font-size: 14px;                            -fx-font-weight: bold; -fx-cursor: hand; -fx-border-color: #7c3aed;                            -fx-border-width: 1.5;" text="Profile">
               <padding>
                  <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
               </padding>
            </Button>
   
                           <!-- New Post Button -->
               <Button fx:id="newPostButton" onAction="#newPostButtonClicked" style="-fx-background-color: #ff6b9d;                            -fx-text-fill: white; -fx-font-family: 'Inter'; -fx-font-size: 14px;                            -fx-font-weight: bold; -fx-cursor: hand; -fx-border-color: transparent;                            -fx-effect: dropshadow(gaussian, rgba(255,107,157,0.5), 8, 0, 0, 0);" text="+ New Post">
                   <font>
                       <Font name="System Bold" size="14.0" />
                   </font>
                   <padding>
                       <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
                   </padding>
               </Button>
            </HBox>
        </HBox>
    </top>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!--  MAIN CONTENT AREA                                      -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <center>
        <HBox alignment="TOP_CENTER" spacing="20.0">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>

            <!-- ─────────────────────────────────────────────── -->
            <!--  FEED (scrollable post list)                    -->
            <!-- ─────────────────────────────────────────────── -->
            <ScrollPane fx:id="feedScroll" fitToWidth="true" hbarPolicy="NEVER" style="-fx-background: transparent; -fx-background-color: transparent;                                -fx-border-color: transparent;" HBox.hgrow="ALWAYS">
                <VBox fx:id="feedContainer" spacing="20.0">
                    <padding>
                        <Insets right="10.0" />
                    </padding>
               <children>
                  <HBox fx:id="PostMockup" prefHeight="100.0" prefWidth="200.0">
                     <children>
                        <ImageView fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true" />
                        <VBox prefHeight="150.0" prefWidth="908.0">
                           <children>
                              <Label prefHeight="35.0" prefWidth="300.0" text="Title of post" textFill="#000000fe">
                                 <font>
                                    <Font size="18.0" />
                                 </font>
                              </Label>
                              <Label prefHeight="31.0" prefWidth="157.0" text="Creator of post" textFill="#000000fc" />
                              <HBox prefHeight="23.0" prefWidth="887.0" />
                              <Label prefHeight="61.0" prefWidth="577.0" text="Label" />
                              <Button mnemonicParsing="false" prefHeight="25.0" prefWidth="190.0" text="Button" />
                           </children>
                        </VBox>
                     </children>
                  </HBox>
               </children>

                </VBox>
            </ScrollPane>

            <!-- ─────────────────────────────────────────────── -->
            <!--  RIGHT SIDEBAR – Trending Tags                  -->
            <!-- ─────────────────────────────────────────────── -->
            <VBox prefWidth="260.0" spacing="0.0" style="-fx-background-color: linear-gradient(to bottom, #ffffff, rgba(254,243,199,0.3));                          -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 8, 0, 0, 2);">

                <!-- Gradient top accent -->
                <Region prefHeight="6.0" style="-fx-background-color: linear-gradient(to right, #ff6b9d, #ffa500);" />

                <VBox spacing="0.0">
                    <padding>
                        <Insets bottom="20.0" left="25.0" right="15.0" top="15.0" />
                    </padding>

                    <Label style="-fx-font-family: 'Playfair Display'; -fx-font-size: 22px;                                   -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="Tags">
                        <VBox.margin>
                            <Insets bottom="12.0" />
                        </VBox.margin>
                    </Label>

                    <FlowPane hgap="10.0" prefHeight="55.0" prefWidth="220.0" prefWrapLength="210.0" vgap="10.0">
                        <children>
                            <Button mnemonicParsing="false" onAction="#showAllPosts" style="-fx-background-color: linear-gradient(to right, rgba(255,107,157,0.18), rgba(255,165,0,0.18)); -fx-text-fill: #1e293b; -fx-font-family: 'Inter'; -fx-font-size: 13px; -fx-font-weight: bold; -fx-border-color: transparent; -fx-background-radius: 999; -fx-border-radius: 999; -fx-cursor: hand;" text="All" />
                            <Button fx:id="Bathroom" mnemonicParsing="false" onAction="#filterByTag" style="-fx-background-color: rgba(61,133,198,0.12); -fx-text-fill: #2563eb; -fx-font-family: 'Inter'; -fx-font-size: 13px; -fx-font-weight: bold; -fx-border-color: transparent; -fx-background-radius: 999; -fx-border-radius: 999; -fx-cursor: hand;" text="Bathroom" />
                            <Button fx:id="Disaster" mnemonicParsing="false" onAction="#filterByTag" style="-fx-background-color: rgba(220,38,38,0.12); -fx-text-fill: #dc2626; -fx-font-family: 'Inter'; -fx-font-size: 13px; -fx-font-weight: bold; -fx-border-color: transparent; -fx-background-radius: 999; -fx-border-radius: 999; -fx-cursor: hand;" text="Disaster" />
                            <Button fx:id="Food" mnemonicParsing="false" onAction="#filterByTag" style="-fx-background-color: rgba(5,150,105,0.12); -fx-text-fill: #059669; -fx-font-family: 'Inter'; -fx-font-size: 13px; -fx-font-weight: bold; -fx-border-color: transparent; -fx-background-radius: 999; -fx-border-radius: 999; -fx-cursor: hand;" text="Food" />
                            <Button fx:id="Movie" mnemonicParsing="false" onAction="#filterByTag" style="-fx-background-color: rgba(124,58,237,0.12); -fx-text-fill: #7c3aed; -fx-font-family: 'Inter'; -fx-font-size: 13px; -fx-font-weight: bold; -fx-border-color: transparent; -fx-background-radius: 999; -fx-border-radius: 999; -fx-cursor: hand;" text="Movie" />
                            <Button fx:id="Music" mnemonicParsing="false" onAction="#filterByTag" style="-fx-background-color: rgba(219,39,119,0.12); -fx-text-fill: #db2777; -fx-font-family: 'Inter'; -fx-font-size: 13px; -fx-font-weight: bold; -fx-border-color: transparent; -fx-background-radius: 999; -fx-border-radius: 999; -fx-cursor: hand;" text="Music" />
                            <Button fx:id="Videogame" mnemonicParsing="false" onAction="#filterByTag" style="-fx-background-color: rgba(59,130,246,0.12); -fx-text-fill: #3b82f6; -fx-font-family: 'Inter'; -fx-font-size: 13px; -fx-font-weight: bold; -fx-border-color: transparent; -fx-background-radius: 999; -fx-border-radius: 999; -fx-cursor: hand;" text="Videogame" />
                            <Button fx:id="Book" mnemonicParsing="false" onAction="#filterByTag" style="-fx-background-color: rgba(120,113,108,0.12); -fx-text-fill: #57534e; -fx-font-family: 'Inter'; -fx-font-size: 13px; -fx-font-weight: bold; -fx-border-color: transparent; -fx-background-radius: 999; -fx-border-radius: 999; -fx-cursor: hand;" text="Book" />
                            <Button fx:id="Other" mnemonicParsing="false" onAction="#filterByTag" style="-fx-background-color: rgba(251,191,36,0.14); -fx-text-fill: #b45309; -fx-font-family: 'Inter'; -fx-font-size: 13px; -fx-font-weight: bold; -fx-border-color: transparent; -fx-background-radius: 999; -fx-border-radius: 999; -fx-cursor: hand;" text="Other" />
                        </children>
                    </FlowPane>

                </VBox>
            </VBox>

        </HBox>
    </center>

</BorderPane>
